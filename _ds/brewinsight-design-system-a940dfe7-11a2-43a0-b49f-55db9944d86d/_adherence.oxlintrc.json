{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/charts/**",
              "components/core/**",
              "ui_kits/instagram/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Caveat|Inter))/i]",
        "message": "Font not provided by the design system. Available: Caveat, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|solid|icon|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, solid, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:forest|amber|sage|neutral|ink|lime)$/]",
        "message": "<Badge> tone must be one of 'forest' | 'amber' | 'sage' | 'neutral' | 'ink' | 'lime'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|fullWidth|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, fullWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:forest|ink|deepGreen|outline|ghost|lime)$/]",
        "message": "<Button> variant must be one of 'forest' | 'ink' | 'deepGreen' | 'outline' | 'ghost' | 'lime'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CornerFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|color|inset|legLength|weight|key|ref|className|style|children)$/]",
        "message": "<CornerFrame> doesn't accept that prop. Declared props: children, variant, color, inset, legLength, weight."
      },
      {
        "selector": "JSXOpeningElement[name.name='CornerFrame'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:clean|hud)$/]",
        "message": "<CornerFrame> variant must be one of 'clean' | 'hud'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DonutGauge'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|size|thickness|color|trackColor|label|showValue|key|ref|className|style|children)$/]",
        "message": "<DonutGauge> doesn't accept that prop. Declared props: value, size, thickness, color, trackColor, label, showValue."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|handle|separator|color|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, handle, separator, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='HudPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:figure|caption|tag|tone|accent|key|ref|className|style|children)$/]",
        "message": "<HudPanel> doesn't accept that prop. Declared props: figure, caption, tag, tone, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='HudPanel'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<HudPanel> tone must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|color|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:mark|lockup|wordmark|footer)$/]",
        "message": "<Logo> variant must be one of 'mark' | 'lockup' | 'wordmark' | 'footer'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pictograph'] > JSXAttribute > JSXIdentifier[name!=/^(?:total|filled|shape|fillColor|emptyColor|size|gap|columns|braceLabel|emptyBraceLabel|key|ref|className|style|children)$/]",
        "message": "<Pictograph> doesn't accept that prop. Declared props: total, filled, shape, fillColor, emptyColor, size, gap, columns, braceLabel, emptyBraceLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pictograph'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:cup|bean|dot|square)$/]",
        "message": "<Pictograph> shape must be one of 'cup' | 'bean' | 'dot' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RangeBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:lowLabel|highLabel|lowCaption|highCaption|fillStart|fillEnd|color|trackColor|ticks|height|key|ref|className|style|children)$/]",
        "message": "<RangeBar> doesn't accept that prop. Declared props: lowLabel, highLabel, lowCaption, highCaption, fillStart, fillEnd, color, trackColor, ticks, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|state|icon|label|key|ref|className|style|children)$/]",
        "message": "<SourceBadge> doesn't accept that prop. Declared props: children, state, icon, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceBadge'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:dark|light|amber)$/]",
        "message": "<SourceBadge> state must be one of 'dark' | 'light' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:figure|caption|sub|accent|align|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: figure, caption, sub, accent, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<StatCard> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrendAnnotation'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|index|key|ref|className|style|children)$/]",
        "message": "<TrendAnnotation> doesn't accept that prop. Declared props: text, index."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
